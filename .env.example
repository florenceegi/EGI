APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=egi
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS General ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-north-1
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- AWS S3 Media Storage (bucket: florenceegi-media, CDN: CloudFront) ---
AWS_BUCKET=florenceegi-media
AWS_URL=https://media.florenceegi.com
MEDIA_DISK=s3
DEFAULT_HOSTING=AWS

VITE_APP_NAME="${APP_NAME}"

# --- COA / Signature (disabled by default) ---
COA_AUTO_GENERATE_PDF=true
COA_SIGNATURE_ENABLED=false
COA_SIGNATURE_PROVIDER=
COA_SIGNATURE_ENV=sandbox
COA_SIGNATURE_HASH=sha256
COA_SIGNATURE_INSPECTOR_ENABLED=false
COA_TSA_ENABLED=false
COA_TSA_POLICY_OID=

# Namirial (placeholders)
NAMIRIAL_SANDBOX_BASE_URL=
NAMIRIAL_SANDBOX_API_KEY=
NAMIRIAL_BASE_URL=
NAMIRIAL_API_KEY=
NAMIRIAL_TSA_SANDBOX_URL=
NAMIRIAL_TSA_SANDBOX_USERNAME=
NAMIRIAL_TSA_SANDBOX_PASSWORD=
NAMIRIAL_TSA_URL=
NAMIRIAL_TSA_USERNAME=
NAMIRIAL_TSA_PASSWORD=

# InfoCert (placeholders)
INFOCERT_SANDBOX_BASE_URL=
INFOCERT_SANDBOX_API_KEY=
INFOCERT_BASE_URL=
INFOCERT_API_KEY=
INFOCERT_TSA_SANDBOX_URL=
INFOCERT_TSA_SANDBOX_USERNAME=
INFOCERT_TSA_SANDBOX_PASSWORD=
INFOCERT_TSA_URL=
INFOCERT_TSA_USERNAME=
INFOCERT_TSA_PASSWORD=

# COA integrity & validity
COA_INTEGRITY_CRITICAL_TRAITS=
COA_VALIDITY_NO_EXPIRY=true

# ============================================================================
# N.A.T.A.N. (Neuro-Analytical Text Analysis Network)
# ============================================================================

# Ollama (Local LLM - GDPR Compliant)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=60

# Anthropic Claude (Cloud LLM - Processes ONLY public metadata)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TIMEOUT=60

# ============================================================================
# ALGORAND BLOCKCHAIN CONFIGURATION
# ============================================================================

# Network Configuration
ALGORAND_NETWORK=testnet
ALGORAND_API_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_API_KEY=

# Treasury Wallet
ALGORAND_TREASURY_ADDRESS=
ALGORAND_TREASURY_MNEMONIC=

# AlgoKit Microservice
ALGOKIT_MICROSERVICE_URL=http://localhost:3000
ALGOKIT_MICROSERVICE_TIMEOUT=30
ALGOKIT_MICROSERVICE_RETRIES=3

# API Settings
ALGORAND_API_TIMEOUT=30
ALGORAND_API_RETRIES=3
ALGORAND_API_RETRY_DELAY=1000
ALGOKIT_API_TOKEN=8f3b2a1c6d9e4f5a8b7c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1
