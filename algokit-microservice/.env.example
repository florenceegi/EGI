# AlgoKit Microservice Configuration

# Server
PORT=3000

# Algorand Network Mode
# Options: sandbox | testnet | mainnet
ALGORAND_NETWORK=sandbox

# Treasury Account Mnemonic
# IMPORTANT: Keep this SECRET! Never commit real mnemonic to git!
# Generate new mnemonic for TestNet/MainNet: https://testnet.algoexplorer.io/
TREASURY_MNEMONIC=misery earn nose palace make together enhance february parade agent oxygen farm ghost canoe forum robot cube office ball energy split annual buddy above absent

# Logging
LOG_LEVEL=info
