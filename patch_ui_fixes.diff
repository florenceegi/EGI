+                        e.stopPropagation();
+
+                        const img = document.getElementById(`egi-link-img-${id}`);
+                        const desc = document.getElementById(`egi-desc-${id}`);
+                        const btn = e.currentTarget;
+                        const span = btn.querySelector('.btn-text');
+                        const labelDesc = btn.dataset.labelDesc;
+                        const labelImg = btn.dataset.labelImg;
+
+                        if (desc.classList.contains('hidden')) {
+                            // Switch to Show Description (so hide img, show desc)
+                            // Button should now say "Image" (to switch back)
+                            img.classList.add('hidden');
+                            img.classList.remove('flex');
+                            desc.classList.remove('hidden');
+                            span.textContent = labelImg;
+                            btn.classList.add('bg-purple-600/80');
+                        } else {
+                            // Switch to Show Image (so hide desc, show img)
+                            // Button should now say "Description"
+                            img.classList.remove('hidden');
+                            img.classList.add('flex');
+                            desc.classList.add('hidden');
+                            span.textContent = labelDesc;
+                            btn.classList.remove('bg-purple-600/80');
+                        }
+                    };
+                </script>
